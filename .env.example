IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
CLIENT_ORIGIN=http://localhost:5173
PORT=8787
HOST=127.0.0.1
IBKR_FLEX_REQUEST_TIMEOUT_MS=30000
IBKR_FLEX_REQUEST_ATTEMPTS=3
IBKR_FLEX_POLL_ATTEMPTS=30
IBKR_FLEX_POLL_MS=10000
IBKR_FLEX_INITIAL_WAIT_MS=20000

# License system (baked into the frontend at build time by Vite). REQUIRED for a
# production build — without these the app falls back to placeholder URLs and
# license activation / "Buy a license" will not work.
VITE_LICENSE_API_URL=https://your-worker-subdomain.workers.dev
VITE_LICENSE_PURCHASE_URL=https://your-store.lemonsqueezy.com/checkout/buy/your-variant-id